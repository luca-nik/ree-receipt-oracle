# Wallet address that receives USDC payments (Base Sepolia)
PAY_TO_ADDRESS=0xYourWalletAddressHere

# Network identifier (Base Sepolia)
NETWORK=eip155:84532

# x402 facilitator URL
FACILITATOR_URL=https://x402.org/facilitator

# Absolute path to ree.sh in the gensyn/ree repo
REE_SH_PATH=/path/to/ree/ree.sh

# Quote TTL in seconds (default: 300 = 5 minutes)
QUOTE_TTL_SECONDS=300
